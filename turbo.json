{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": { "dependsOn": ["^build"], "outputs": ["dist/**", ".next/**"] },
    "dev": { "cache": false, "persistent": true },
    "lint": { "dependsOn": ["^build"] },
    "typecheck": { "dependsOn": ["^build"] },
    "test": { "dependsOn": ["^build"] },
    "test:unit": {},
    "test:integration": {},
    "test:contract": {},
    "test:visual": {},
    "test:a11y": {},
    "test:security": {},
    "test:ai": {},
    "test:claim-safety": {},
    "test:no-fairy-tale": {},
    "test:prompt-regression": {},
    "validate:schemas": {},
    "eval": {},
    "clean": { "cache": false }
  }
}
