# ============================================
# AVG Lab — Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values
# Command: cp .env.template .env
# ============================================

# --- AI Provider (Required) ---
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Optional: Alternative AI provider endpoint (for compatible APIs)
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Database Configuration ---
# PostgreSQL server settings
POSTGRES_SERVER=83.166.253.250
AVG_DATABASE_MODE=postgres
POSTGRES_USER=avg
POSTGRES_PASSWORD=avg2026
POSTGRES_DB=avg_dev

# Full database URL (auto-generated from above variables)
DATABASE_URL=postgresql://avg:avg2026@83.166.253.250:5432/avg_dev

# Optional: Local Docker database (uncomment if using docker-compose)
# DATABASE_URL=postgresql://avg:avg@localhost:5432/avg
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10

# --- Cache (Redis) ---
REDIS_URL=redis://localhost:6379

# Optional: Redis password (if enabled in docker-compose)
# REDIS_PASSWORD=

# --- Graph Database (Neo4j) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Optional: Neo4j database name
# NEO4J_DATABASE=neo4j

# --- Object Storage (S3 Compatible) ---
# Used for artifact export and file uploads
S3_BUCKET=avg-dev
S3_REGION=auto
S3_ENDPOINT=http://localhost:9000

# Optional: S3 credentials (for production)
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# --- Error Monitoring (Sentry) ---
# Get your DSN from: https://sentry.io/
SENTRY_DSN=https://...@sentry.io/...

# Optional: Sentry environment
# SENTRY_ENVIRONMENT=development

# --- AI Observability (Langfuse) ---
# Get your keys from: https://cloud.langfuse.com/
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Optional: Langfuse host
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- Product Analytics (PostHog) ---
# Get your key from: https://app.posthog.com/
POSTHOG_KEY=phc_...

# Optional: PostHog host
# POSTHOG_HOST=https://app.posthog.com

# --- Application Settings (Optional) ---
# NODE_ENV=development
# PORT=3000
# LOG_LEVEL=debug
