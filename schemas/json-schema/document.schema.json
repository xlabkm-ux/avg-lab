{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avg.local/schemas/document.schema.json",
  "title": "AVG Document Reference",
  "type": "object",
  "required": ["id", "project_id", "title", "source_kind", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source_kind": {
      "type": "string",
      "enum": ["local_text", "local_markdown", "local_document"]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
