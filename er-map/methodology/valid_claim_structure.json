      "label": {
        "ru": "Структура допустимого утверждения",
        "short": "Допустимое утверждение"
      },
      "definition": {
        "text": "Каждое утверждение в модели ЭР должно содержать явные компоненты: область определения, статус утверждения, режим доступности, координаты (уровень вложенности, объектность, твёрдость). Без этих компонентов утверждение считается некорректным.",
        "definition_type": "methodological_definition",
        "source_refs": ["vol_1_reality"]
      },
      "coordinates": {
        "nesting_level": "reality",
        "objectivity_mode": "mixed",
        "hardness_mode": "mixed",
        "access_mode": "mixed",
        "world_subdomain": null
      },
