  "items": [
    {
      "id": "objective_reality_mode",
      "type": "concept",
      "label": {
        "ru": "Объективная Реальность (ОР)",
        "short": "ОР"
      },
      "definition": {
        "text": "Режим описания, предполагающий существование независимо от наблюдателя. Объективная Реальность — это аспект описания, не онтологическая сущность.",
        "definition_type": "working_distinction",
        "source_refs": ["vol_1_reality"]
      },
      "coordinates": {
        "nesting_level": "world",
        "objectivity_mode": "objective",
        "hardness_mode": "mixed",
        "access_mode": "mixed",
        "world_subdomain": null
      },
      "language_policy": {
        "allowed_modes": [
          "direct_description",
          "operational_description"
        ],
        "forbidden_modes": [],
        "notes": "ОР допускает прямое описание для твёрдого и операциональное для нетвёрдого."
      },
      "claim_policy": {
        "default_claim_status": "working_distinction",
        "positive_claims_allowed": true,
        "requires_scope_boundary": true,
        "requires_access_mode": false
      }
    },
    {
      "id": "subjective_reality_mode",
      "type": "concept",
      "label": {
        "ru": "Субъективная Реальность (СР)",
        "short": "СР"
      },
      "definition": {
        "text": "Режим описания, зависящий от наблюдателя/субъекта. Субъективная Реальность включает переживания, смыслы, интерпретации.",
        "definition_type": "working_distinction",
        "source_refs": ["vol_1_reality"]
      },
      "coordinates": {
        "nesting_level": "world",
        "objectivity_mode": "subjective",
        "hardness_mode": "mixed",
        "access_mode": "mixed",
        "world_subdomain": null
      },
      "language_policy": {
        "allowed_modes": [
          "direct_description",
          "conditional_description",
          "operational_description"
        ],
        "forbidden_modes": [
          "objectifying_description"
        ],
        "notes": "СР требует учёта перспективы субъекта; прямое объектное описание неадекватно."
      },
      "claim_policy": {
        "default_claim_status": "working_distinction",
        "positive_claims_allowed": true,
        "requires_scope_boundary": true,
        "requires_access_mode": false
      }
    },
    {
      "id": "hard_world_intersection",
      "type": "concept",
      "label": {
        "ru": "Твёрдый Мир как пересечение ОР и СР",
        "short": "ОР ∩ СР"
      },
      "definition": {
        "text": "Твёрдый Мир — область пересечения объективной и субъективной реальности. То, что одновременно существует объективно и доступно субъективному переживанию.",
        "definition_type": "working_distinction",
        "source_refs": ["vol_1_reality"]
      },
      "coordinates": {
        "nesting_level": "world",
        "objectivity_mode": "mixed",
        "hardness_mode": "hard",
        "access_mode": "knowable",
        "world_subdomain": "material_world"
      },
      "claim_policy": {
        "default_claim_status": "working_distinction",
        "positive_claims_allowed": true,
        "requires_scope_boundary": true,
        "requires_access_mode": true
      },
      "map_safety": {
        "known_risks": [
          "level_mixing",
          "access_mode_mixing"
        ],
        "anti_substitution_rule": "Не отождествлять пересечение с полным тождеством ОР и СР."
      }
    }
  ]
}
