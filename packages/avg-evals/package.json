{
  "name": "@avg/evals",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --experimental-strip-types ../../scripts/evals/ai-check.ts",
    "test:ai": "node --experimental-strip-types ../../scripts/evals/ai-check.ts",
    "test:claim-safety": "node --experimental-strip-types ../../scripts/evals/claim-safety-check.ts",
    "test:no-fairy-tale": "node --experimental-strip-types ../../scripts/evals/no-fairy-tale-check.ts",
    "test:prompt-regression": "node --experimental-strip-types ../../scripts/evals/prompt-regression-check.ts",
    "eval": "node --experimental-strip-types ../../scripts/evals/ai-check.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@avg/utils": "workspace:*"
  }
}
